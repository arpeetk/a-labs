{
  "expo": {
    "name": "a-labs",
    "slug": "a-labs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Required to record clinical encounters for documentation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": ["expo-av"]
  }
}

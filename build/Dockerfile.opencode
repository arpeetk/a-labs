# wren/opencode-runner: a harness image with the OpenCode CLI + git and the
# wren-runtime binary as entrypoint. The operator uses this as a project's
# harness image; wren-runtime's harness role drives `opencode run` in the cloned
# workspace.
#
# Model calls ride the Anthropic route: the adapter renders an opencode config
# pointing the anthropic provider's baseURL at ANTHROPIC_BASE_URL (the in-pod
# egress-proxy), which injects the real key — so this image ships no
# credentials.
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /out/wren-runtime ./cmd/wren-runtime

FROM node:22-bookworm-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g opencode-ai \
 && npm cache clean --force
COPY --from=build /out/wren-runtime /usr/local/bin/wren-runtime
# Non-root agent user at uid 65532: MUST match the operator's pinned runner uid
# (internal/controller/pod.go runnerUID) — the WS-1 egress uid-boundary depends
# on the harness NOT running as the proxy's uid (65533), and matching the
# distroless runtime image lets the harness own the files hydrate cloned.
# HOME/tmp/workspace are writable volumes at runtime.
RUN useradd -m -u 65532 agent
USER 65532:65532
ENV HOME=/home/agent XDG_CACHE_HOME=/tmp/.cache
WORKDIR /home/agent
ENTRYPOINT ["/usr/local/bin/wren-runtime"]
